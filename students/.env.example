# Скопіюйте: cp students/.env.example students/.env
# Файл students/.env у git не потрапляє.
#
# На PythonAnywhere ті самі KEY=VALUE додайте в:
#   Web → Environment variables  (для сайту)
#   Tasks → Always-on → Environment  (для bot/main)

# Погода (OpenWeatherMap, WeatherAPI, …)
WEATHER_API_KEY=

# Курси валют (exchangerate-api, fixer.io, …)
EXCHANGE_RATE_API_KEY=

# OpenAI / інші LLM
OPENAI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# Будь-які свої сервіси — довільні імена UPPER_SNAKE_CASE:
# MY_SERVICE_TOKEN=
